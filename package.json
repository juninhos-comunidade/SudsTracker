{
  "name": "suds-tracker-",
  "version": "1.0.0",
  "description": "<h1 align=\"center\">🧠 SUDS Tracker</h1>",
  "main": "index.js",
  "private": "true",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "start:backend": "npm run dev --prefix apps/backend",
    "start:frontend": "npm run dev --prefix apps/frontend",
