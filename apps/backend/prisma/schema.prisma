// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}
datasource db {
  provider = "postgresql"
}

model Usuario {
  id        String   @id @default(uuid())
  nome      String
  dataNascimento     DateTime
  email     String   @unique
  senha     String
  ativo     Boolean @default(true)
  tipoUsuario     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  profissional Profissional?
  paciente Paciente?
}

model Profissional {
 id Int @id @default(autoincrement())
 id_usuario String @unique
 telefone String
 especialidade String
 crm String?
 crp String?
 crefito String?

usuario Usuario @relation(fields: [id_usuario], references: [id])

 pacientes Paciente[]
 avaliacoes Avaliacao[]

}

model Paciente {
 id Int @id @default(autoincrement())
 id_usuario String @unique
 id_profissional Int?

 usuario Usuario @relation(fields: [id_usuario], references: [id])
 profissional Profissional? @relation(fields: [id_profissional], references: [id])

 anotacoes Anotacao[]
 avaliacoes Avaliacao[]

}

model Anotacao {
 id Int @id @default(autoincrement())
 id_paciente Int
 intensidade Int
 sentimento String
 anotacao String
 gatilhos String 
 estrategias String
 createAt DateTime @default(now())
 updateAt DateTime @updatedAt

 paciente Paciente @relation(fields: [id_paciente], references: [id])

}

model Avaliacao {
  id                  Int          @id @default(autoincrement())
  id_paciente         Int
  id_profissional     Int
  titulo              String?    
  tecnicas_utilizadas String?    
  evolucao_percebida  String?      
  pontos_positivos    String?      
  suds_observado      Int?         
  objetivo_semana     String?      
  mensagem_paciente   String?      
  
  createAt            DateTime     @default(now())
  updateAt            DateTime     @updatedAt

  paciente            Paciente     @relation(fields: [id_paciente], references: [id])
  profissional        Profissional @relation(fields: [id_profissional], references: [id])
}


